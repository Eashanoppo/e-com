# -----------------------------------------------------------------------------
# Ridy’s Hena Art - Environment Variables Example
# -----------------------------------------------------------------------------
# Instructions:
# 1. Copy this file to .env.local
# 2. Fill in the actual values from your service dashboards
# -----------------------------------------------------------------------------

# --- NextAuth.js Configuration (Fixes "invalid_client" Error) ---
# 1. Go to: https://console.cloud.google.com/
# 2. Add an "OAuth Client ID" (Web Application)
# 3. SET AUTHORIZED REDIRECT URI: http://localhost:3000/api/auth/callback/google
# 4. Copy the Client ID and Secret to your .env.local
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."
NEXTAUTH_SECRET=your-random-secret-key-minimum-32-chars
NEXTAUTH_URL=http://localhost:3000

# --- Supabase (Database) ---
# Get these from: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-admin-actions

# --- Google Gemini AI (for Mehendi Expert Chat) ---
# Get this from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-google-ai-studio-api-key

# --- Cloudinary (Image Optimization & Storage) ---
# Get these from: Cloudinary Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- App Settings ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development
